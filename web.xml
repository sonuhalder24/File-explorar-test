<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  <servlet>
  	<servlet-name>EditFile</servlet-name>
  	<display-name>EditFile</display-name>
  	<description></description>
  	<servlet-class>EditFile</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>Editor</servlet-name>
  	<display-name>Editor</display-name>
  	<description></description>
  	<servlet-class>Editor</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>FileExplorer</servlet-name>
  	<display-name>FileExplorer</display-name>
  	<description></description>
  	<servlet-class>FileExplorer</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>SaveFile</servlet-name>
  	<display-name>SaveFile</display-name>
  	<description></description>
  	<servlet-class>SaveFile</servlet-class>
  </servlet>
  <servlet-mapping>
  	<servlet-name>EditFile</servlet-name>
  	<url-pattern>/EditFile</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>Editor</servlet-name>
  	<url-pattern>/Editor</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>FileExplorer</servlet-name>
  	<url-pattern>/FileExplorer</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>SaveFile</servlet-name>
  	<url-pattern>/SaveFile</url-pattern>
  </servlet-mapping>
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

</web-app>
